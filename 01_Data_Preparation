%MACRO APPEND_T20;
    DATA D_OUT.T20_ALL;
        SET 
        %DO Y = 2010 %TO 2023;
            R_RAW.T20_&Y.01 - R_RAW.T20_&Y.12
        %END;
        ;
        YEAR = SUBSTR(MDCARE_STRT_DT, 1, 4);
        DATE = SUBSTR(MDCARE_STRT_DT, 1, 6);
    RUN;
%MEND;
%APPEND_T20;

PROC SQL;
    CREATE TABLE D_OUT.BASE_CLAIMS AS
    SELECT A.*, B.GAIBJA_TYPE, B.CALC_CTRB_FD, B.CMPR_DSB_GRADE, B.BIRTH_YYYYMM, B.SEX_TYPE, B.ID_SGG AS ID_SGG2, B.INDTP_CD
    FROM D_OUT.T20_ALL AS A
    LEFT JOIN D_OUT.BFC_GEO AS B ON (A.INDI_DSCM_NO = B.INDI_DSCM_NO AND A.YEAR = B.STD_YYYY);
QUIT;

/* -------------------------------------------------------------------------
   Step 3: Extracting Pediatric Respiratory Cases
------------------------------------------------------------------------- */
DATA D_OUT.RESPIRATORY_CASES;
    SET D_OUT.BASE_CLAIMS;
    DISEASE_1 = SUBSTR(SICK_SYM1, 1, 3);
    DISEASE_2 = SUBSTR(SICK_SYM2, 1, 3);
    
    IF DISEASE_1 IN ('J00', 'J01', 'J02', 'J03', 'J04', 'J06', 'J12', 'J13', 'J14', 'J15', 'J18', 
                     'J20', 'J21', 'J22', 'J30', 'J31', 'J32', 'J40', 'J41', 'J42', 'J45', 'J46', 
                     'J68', 'J69', 'J80', 'J96', 'J98', 'J77') 
    OR DISEASE_2 IN ('J00', 'J01', 'J02', 'J03', 'J04', 'J06', 'J12', 'J13', 'J14', 'J15', 'J18', 
                     'J20', 'J21', 'J22', 'J30', 'J31', 'J32', 'J40', 'J41', 'J42', 'J45', 'J46', 
                     'J68', 'J69', 'J80', 'J96', 'J98', 'J77');
                     
    COUNT_UNIQ = 1;
RUN;

PROC SQL;
    CREATE TABLE D_OUT.RESPIRATORY_MONTHLY AS
    SELECT INDI_DSCM_NO, DATE, ID_SGG2 AS ID_SGG, BIRTH_YYYYMM, SEX_TYPE, GAIBJA_TYPE, CALC_CTRB_FD, CMPR_DSB_GRADE, INDTP_CD,
           SUM(ED_RC_TOT_AMT) AS TOT, SUM(EDC_SBA) AS SELF, SUM(EDC_INSUR_BRDN_AMT) AS INSUR, SUM(COUNT_UNIQ) AS COUNT_A
    FROM D_OUT.RESPIRATORY_CASES
    GROUP BY INDI_DSCM_NO, DATE, ID_SGG2, BIRTH_YYYYMM, SEX_TYPE, GAIBJA_TYPE, CALC_CTRB_FD, CMPR_DSB_GRADE, INDTP_CD;
QUIT;

/* -------------------------------------------------------------------------
   Step 4: Create Balanced Panel
------------------------------------------------------------------------- */
PROC SQL;
    CREATE TABLE D_OUT.ALL_COMBINATIONS AS 
    SELECT A.INDI_DSCM_NO, B.DATE
    FROM (SELECT DISTINCT INDI_DSCM_NO FROM D_OUT.RESPIRATORY_MONTHLY) AS A
    CROSS JOIN (SELECT DISTINCT DATE FROM D_OUT.RESPIRATORY_MONTHLY) AS B;
QUIT;

PROC SQL;
    CREATE TABLE D_OUT.PANEL_FILLED AS 
    SELECT A.INDI_DSCM_NO, A.DATE, B.*
    FROM D_OUT.ALL_COMBINATIONS AS A
    LEFT JOIN D_OUT.RESPIRATORY_MONTHLY AS B ON A.INDI_DSCM_NO = B.INDI_DSCM_NO AND A.DATE = B.DATE;
QUIT;

DATA D_OUT.PANEL_CLEAN;
    SET D_OUT.PANEL_FILLED;
    IF COUNT_A = . THEN COUNT_A = 0;
    IF TOT = . THEN TOT = 0;
    YEARLY = SUBSTR(DATE, 1, 4);
    MONTHLY = SUBSTR(DATE, 5, 2);
RUN;

/* -------------------------------------------------------------------------
   Step 5: Merge Covariates & Environmental Data (KEEP over50_avg, MRAIN)
------------------------------------------------------------------------- */
PROC SQL;
    CREATE TABLE D_OUT.PANEL_COV AS
    SELECT A.*, B.BTH_WGHT, B.PREM, B.BTH_DATE
    FROM D_OUT.PANEL_CLEAN AS A
    LEFT JOIN D_OUT.CHECKUP_CLEANED AS B ON A.INDI_DSCM_NO = B.INDI_DSCM_NO;
QUIT;

PROC IMPORT DATAFILE="/userdata01/room022/data_out/data_out/env_data.xlsx"
    OUT=D_OUT.ENV_DATA DBMS=XLSX REPLACE;
RUN;

DATA D_OUT.ENV_CLEAN;
    SET D_OUT.ENV_DATA;
    YEAR = INPUT(SUBSTR(PUT(MONTH2, 6.), 1, 4), 4.);
    MONTH = INPUT(SUBSTR(PUT(MONTH2, 6.), 5, 2), 2.);		
    DATE = COMPRESS(PUT(YEAR * 100 + MONTH, 6.)); 
    
    /* Rename the pre-calculated variable to be more intuitive for Stata */
    high_pm25 = over50_avg;
    
    KEEP ID_SGG DATE MPM10 MPM25 high_pm25 TI_MEAN_ZERO MRAIN;
RUN;

PROC SORT DATA=D_OUT.ENV_CLEAN; BY ID_SGG DATE; RUN;

PROC SQL;
    CREATE TABLE D_OUT.FINAL_MERGE AS
    SELECT A.*, B.MPM10, B.MPM25, B.high_pm25, B.TI_MEAN_ZERO, B.MRAIN
    FROM D_OUT.PANEL_COV AS A
    INNER JOIN D_OUT.ENV_CLEAN AS B ON A.ID_SGG = B.ID_SGG AND A.DATE = B.DATE;
QUIT;

/* -------------------------------------------------------------------------
   Step 6: Final Data Trimming and Adjustments
------------------------------------------------------------------------- */
PROC SQL;
    CREATE TABLE D_OUT.FINAL AS
    SELECT * FROM D_OUT.FINAL_MERGE
    WHERE INDI_DSCM_NO NOT IN (
        SELECT INDI_DSCM_NO FROM D_OUT.FINAL_MERGE GROUP BY INDI_DSCM_NO HAVING COUNT(DISTINCT ID_SGG) > 1
    );
QUIT;

DATA D_OUT.FINAL_READY;
    SET D_OUT.FINAL;
    
    IF GAIBJA_TYPE = 6 OR GAIBJA_TYPE = "";
    
    DIFF_BTH = INTCK('MONTH', INPUT(BIRTH_YYYYMM, YYMMN6.), INPUT(DATE, YYMMN6.));
    IF 0 <= DIFF_BTH <= 95; 
    
    INDTP = SUBSTR(INDTP_CD, 1, 2);
    JOB1 = (INDTP IN ("01", "02", "03"));
    JOB2 = (INDTP IN ("04", "05", "06"));
    JOB3 = (INDTP IN ("07", "08", "09"));
    JOB4 = ("09" < INDTP < "98");
    JOB5 = ("98" < INDTP OR INDTP = .);
    
    DSB = (CMPR_DSB_GRADE ~= .);
    SEX = (SEX_TYPE = "1");
    
    IF PREM = 2 THEN PREM = 0; 
    ELSE IF PREM = 1 THEN PREM = 1; 
    
    SELECT (YEARLY);
        WHEN ("2010") RATIO = 86.4;
        WHEN ("2011") RATIO = 89.9;
        WHEN ("2012") RATIO = 91.8;
        WHEN ("2013") RATIO = 93.0;
        WHEN ("2014") RATIO = 94.2;
        WHEN ("2015") RATIO = 94.861;
        WHEN ("2016") RATIO = 95.783;
        WHEN ("2017") RATIO = 97.645;
        WHEN ("2018") RATIO = 99.086;
        WHEN ("2019") RATIO = 99.466;
        WHEN ("2020") RATIO = 100.0;
        WHEN ("2021") RATIO = 102.50;
        WHEN ("2022") RATIO = 107.7;
        WHEN ("2023") RATIO = 111.6;
    END;
    
    RCALC = (CALC_CTRB_FD / RATIO) * 100;
    RTOT = (TOT / RATIO) * 100;

    IF YEARLY >= "2015";
    IF CALC_CTRB_FD = . THEN DELETE;
    IF TOT = . THEN DELETE;

    KEEP INDI_DSCM_NO DATE ID_SGG DIFF_BTH TOT RTOT CALC_CTRB_FD RCALC 
         COUNT_A DSB JOB1 JOB2 JOB3 JOB4 JOB5 SEX BTH_WGHT PREM MPM10 MPM25 high_pm25 TI_MEAN_ZERO MRAIN;
RUN;

/* -------------------------------------------------------------------------
   Step 7: Export to Stata
------------------------------------------------------------------------- */
PROC EXPORT DATA=D_OUT.FINAL_READY
    OUTFILE="/userdata01/room022/data_out/2010_2023_ALL/respiratory_2015_2023.dta"
    DBMS=STATA REPLACE;
RUN;
