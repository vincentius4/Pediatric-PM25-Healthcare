/* =========================================================================
   Project: Impact of PM2.5 on Pediatric Respiratory Healthcare Utilization
   Script: 01_Data_Preparation.sas
   Description: Data cleaning, variable construction, and monthly aggregation 
   Output: respiratory_2015_2023.dta (Monthly Panel for Stata Analysis)
   Note: Raw NHIS data can only be accessed offline at NHIS Big Data Centers.
========================================================================= */

/* -------------------------------------------------------------------------
   Step 0: Set Libraries
------------------------------------------------------------------------- */
LIBNAME R_RAW "/userdata01/room022/data_source/user_data/" COMPRESS=YES;
LIBNAME D_OUT "/userdata01/room022/data_out/2010_2023_ALL/" COMPRESS=YES;		
LIBNAME D_INFANT "/userdata01/room022/data_out/infant/" COMPRESS=YES;

/* -------------------------------------------------------------------------
   Step 1: Infant Health Checkup Data (Extract birth date/month & baseline info)
------------------------------------------------------------------------- */
%MACRO PROCESS_HEALTH_CHECKUP;
    %DO N = 1 %TO 7;
        DATA D_OUT.YOUNG_E&N.;
            SET R_RAW.I&N.E_RST_2008 - R_RAW.I&N.E_RST_2018
                R_RAW.I&N.E_RST_2019 (RENAME=(HC_DT=HME_DT)) - R_RAW.I&N.E_RST_2023 (RENAME=(HC_DT=HME_DT));
            KEEP INDI_DSCM_NO HME_DT I&N.E_HGHT I&N.E_WGHT;
        RUN;
        
        DATA D_OUT.YOUNG_Q&N.;
            SET R_RAW.I&N.Q_RST_2008 - R_RAW.I&N.Q_RST_2018
                R_RAW.I&N.Q_RST_2019 (RENAME=(HC_DT=HME_DT)) - R_RAW.I&N.Q_RST_2023 (RENAME=(HC_DT=HME_DT));
            KEEP INDI_DSCM_NO I&N.Q_BTH_WGHT I&N.Q_PREM I&N.Q_BTH_DATE HME_DT;
        RUN;
    %END;
%MEND;
%PROCESS_HEALTH_CHECKUP;

PROC SQL;
    CREATE TABLE D_OUT.A_Q_FINAL AS
    SELECT COALESCE(Q1.INDI_DSCM_NO, Q2.INDI_DSCM_NO, Q3.INDI_DSCM_NO, Q4.INDI_DSCM_NO, Q5.INDI_DSCM_NO, Q6.INDI_DSCM_NO, Q7.INDI_DSCM_NO) AS INDI_DSCM_NO, 
           Q1.*, Q2.*, Q3.*, Q4.*, Q5.*, Q6.*, Q7.*
    FROM D_OUT.YOUNG_Q1 AS Q1
    FULL JOIN D_OUT.YOUNG_Q2 AS Q2 ON Q1.INDI_DSCM_NO = Q2.INDI_DSCM_NO
    FULL JOIN D_OUT.YOUNG_Q3 AS Q3 ON COALESCE(Q1.INDI_DSCM_NO, Q2.INDI_DSCM_NO) = Q3.INDI_DSCM_NO
    FULL JOIN D_OUT.YOUNG_Q4 AS Q4 ON COALESCE(Q1.INDI_DSCM_NO, Q2.INDI_DSCM_NO, Q3.INDI_DSCM_NO) = Q4.INDI_DSCM_NO
    FULL JOIN D_OUT.YOUNG_Q5 AS Q5 ON COALESCE(Q1.INDI_DSCM_NO, Q2.INDI_DSCM_NO, Q3.INDI_DSCM_NO, Q4.INDI_DSCM_NO) = Q5.INDI_DSCM_NO
    FULL JOIN D_OUT.YOUNG_Q6 AS Q6 ON COALESCE(Q1.INDI_DSCM_NO, Q2.INDI_DSCM_NO, Q3.INDI_DSCM_NO, Q4.INDI_DSCM_NO, Q5.INDI_DSCM_NO) = Q6.INDI_DSCM_NO
    FULL JOIN D_OUT.YOUNG_Q7 AS Q7 ON COALESCE(Q1.INDI_DSCM_NO, Q2.INDI_DSCM_NO, Q3.INDI_DSCM_NO, Q4.INDI_DSCM_NO, Q5.INDI_DSCM_NO, Q6.INDI_DSCM_NO) = Q7.INDI_DSCM_NO;
QUIT;

PROC SORT DATA=D_OUT.A_Q_FINAL NODUPKEY; BY INDI_DSCM_NO; RUN;

DATA D_OUT.CHECKUP_CLEANED;
    SET D_OUT.A_Q_FINAL;
    
    BTH_WGHT = COALESCE(I1Q_BTH_WGHT, I2Q_BTH_WGHT, I3Q_BTH_WGHT, I4Q_BTH_WGHT, I5Q_BTH_WGHT, I6Q_BTH_WGHT, I7Q_BTH_WGHT);
    IF BTH_WGHT = . THEN DELETE;
    IF BTH_WGHT > 10 THEN BTH_WGHT = BTH_WGHT / 10; 
    
    PREM = COALESCE(I1Q_PREM, I2Q_PREM, I3Q_PREM, I4Q_PREM, I5Q_PREM, I6Q_PREM, I7Q_PREM);
    IF PREM = . THEN DO;
        IF BTH_WGHT >= 2.5 THEN PREM = 2; 
        ELSE PREM = 1; 
    END;
    
    BTH_DATE = COALESCE(I1Q_BTH_DATE, I2Q_BTH_DATE, I3Q_BTH_DATE, I4Q_BTH_DATE, I5Q_BTH_DATE, I6Q_BTH_DATE, I7Q_BTH_DATE);
    KEEP INDI_DSCM_NO BTH_WGHT PREM BTH_DATE;
RUN;

/* -------------------------------------------------------------------------
   Step 2: Medical Claims Data Processing & Regional Mapping
------------------------------------------------------------------------- */
DATA D_OUT.BFC_ALL;
    SET R_RAW.BFC_2002 - R_RAW.BFC_2023;
RUN;

PROC SQL;
    CREATE TABLE D_OUT.BFC_ALL_BIRTH AS
    SELECT A.*, B.BIRTH_YYYYMM
    FROM D_OUT.BFC_ALL AS A
    LEFT JOIN R_RAW.TARGET_BIRTHYYYYMM AS B ON A.INDI_DSCM_NO = B.INDI_DSCM_NO;
QUIT;

